# NOP-CHAOS 集成配置

# 启用 NOP-CHAOS 集成（默认关闭）
VITE_ENABLE_NOP_INTEGRATION=true

# 允许的父窗口来源（逗号分隔）
# 开发环境：允许本地开发服务器
VITE_NOP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# 生产环境示例（取消注释并修改为实际域名）
# VITE_NOP_ALLOWED_ORIGINS=https://your-nop-chaos-domain.com

# API 端点（可选，用于后端集成）
# VITE_API_BASE_URL=http://localhost:8080/api